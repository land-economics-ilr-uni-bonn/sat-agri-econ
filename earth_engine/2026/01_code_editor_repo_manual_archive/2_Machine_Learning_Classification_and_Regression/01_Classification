////########################################################
//// Training accuracy
////########################################################


// Confusion matrix
var confMat = trained.confusionMatrix();
print('Confusion matrix', confMat);

// Overall accuracy
var OA_train = confMat.accuracy();
print('Overall accuracy', OA_train);

// Producer's accuracy = 1 - omission error
var PA_train = confMat.producersAccuracy();
print("Producer's accuracy", PA_train);

// User's accuracy = 1 - commission error
var UA_train = confMat.consumersAccuracy();
print("User's accuracy", UA_train);



////########################################################
//// Validation accuracy
////########################################################


var validation_predicted = validation.classify(trained);

print("validation_predicted.first()", validation_predicted.first());


// Error matrix
var errMat = validation_predicted.errorMatrix({
  actual: 'klassId', 
  predicted: 'classification'
});

print('Error matrix', errMat);

// Overall accuracy
var OA_valid = errMat.accuracy();
print('Overall accuracy', OA_valid);

// Producer's accuracy = 1 - omission error
var PA_valid = errMat.producersAccuracy();
print("Producer's accuracy", PA_valid);

// User's accuracy = 1 - commission error
var UA_valid = errMat.consumersAccuracy();
print("User's accuracy", UA_valid);




////########################################################
//// Predicted class probability
////########################################################

// Instantiate the classifier, train it
var classifier_PROB = ee.Classifier.smileRandomForest(20)
    .setOutputMode('MULTIPROBABILITY')
    .train({
      features: sampleWithCovariates, 
      classProperty: 'klassId', 
      inputProperties: composite.bandNames()
    });

// Apply the classifier the whole image in AOI
var classified_PROB = composite.clip(AOI).classify(classifier_PROB);

print('classified_PROB', classified_PROB);

Map.addLayer(classified_PROB, {}, 'classified_PROB', false);
// Use inspector to check value, it's a one-band array image, the element of the array is probability for a class

// Convert the array image to a multiband image, each band for each class (six classes in this example)
var classified_PROB_multibands = classified_PROB
  .arrayFlatten([['class_0', 'class_1', 'class_2', 'class_3', 'class_4', 'class_5']]);

print('classified_PROB_multibands', classified_PROB_multibands); // multiband image

// Visualize probability for some classes, see training polygons for class id and class name
Map.addLayer(classified_PROB_multibands.select('class_0'), {min:0, max:1}, "Probability - 'Urban'");
Map.addLayer(classified_PROB_multibands.select('class_4'), {min:0, max:1}, "Probability - 'Oil Palm'");