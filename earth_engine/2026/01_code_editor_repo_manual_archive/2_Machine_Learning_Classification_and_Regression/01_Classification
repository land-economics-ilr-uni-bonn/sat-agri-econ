Map.addLayer(compositeS2, 
    {min:[0,0,0], max:[3000,4000,2000], bands:['swir1','nir','red']}, 'Sentinel-2 composite');


// Merge Landsat, Sentinel-1, and Sentinel-2
var composite = ee.Image.cat(compositeL8, compositeS1, compositeS2);
print('composite', composite);



////########################################################
//// Training data
////########################################################

// Training samples digitized on the map. One feature collection for one class.
// Merge into one feature collection.
var sample = Urban.merge(Water).merge(Bare)
             .merge(Cropland).merge(OilPalm)
             .merge(Rubber);



// Extract covariates at the samples
var sampleWithCovariates = composite.sampleRegions({
  collection: sample, 
  scale: 30, 
  geometries: true
});


var histogram = sampleWithCovariates.reduceColumns({
  reducer: ee.Reducer.frequencyHistogram(), 
  selectors: ['klassId']
});
print(histogram); 



////########################################################
//// Training set and validation set
////########################################################


sampleWithCovariates = sampleWithCovariates.randomColumn({ seed: 1 });

var training = sampleWithCovariates.filter(ee.Filter.lt('random', 0.7));

var validation = sampleWithCovariates.filter(ee.Filter.gte('random', 0.7));

print("training.size()", training.size());

print("validation.size()", validation.size());



////########################################################
//// Classification
////########################################################

// Instantiate the classifier
var classifier = ee.Classifier.smileRandomForest(20);


// Train the classifier
var trained = classifier.train({
      features: training, 
      classProperty: 'klassId', 
      inputProperties: composite.bandNames()
    });


// Apply the classifier the whole image in AOI
var classified = composite.clip(AOI).classify(trained);


Map.addLayer(classified, 
       {min: 0, max: 5, 
       palette:['gray','blue','brown','yellow','green','orange']}, 
       'classified');

/* Classes
0: Urban
1: Water
2: Bare
3: Cropland
4: OilPalm
5: Rubber
*/

Map.centerObject(AOI);
Map.setOptions('SATELLITE');




