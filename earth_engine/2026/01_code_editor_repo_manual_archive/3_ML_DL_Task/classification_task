/*
SATELLITE DATA FOR AGRICULTURAL AND ENVIRONMENTAL ECONOMICS

THEORY AND PRACTICE

Mapping tea plantations in Central Kenya: Machine Learning Approach
David Wuepper, Lisa Biber-Freudenberger, Hadi, Wyclife Agumba Oluoch
Affiliations:
  - Land Economics Group (https://www.ilr1.uni-bonn.de/en/research/research-groups/land-economics), University of Bonn, Bonn, Germany
  - Center for Development Research (https://www.zef.de/zefhome.html), University of Bonn, Bonn, Germany

This script demonstrates how to generate a cloud-free Sentinel-2 composite and use Random Forest classification
to map tea plantations. It includes preprocessing, training data preparation, classification, accuracy assessment,
and export of the final classified image for external use.
*/

// ----------------------------------------------------
// 1. Select Spectral Bands for Classification
// ----------------------------------------------------
// These bands include visible (B2, B3, B4), red edge (B5, B6, B7, B8A), NIR (B8), and SWIR (B11, B12) that are
// important for vegetation discrimination.

s2 = s2.select('B2', 'B3', 'B4', 'B5', 'B6', 'B7', 'B8', 'B8A', 'B11', 'B12');

// ----------------------------------------------------
// 2. Define Time Range and Cloud Score Threshold
// ----------------------------------------------------

var start_date = "2023-01-01";  // Beginning of image acquisition period
var end_date = "2023-12-31";    // End of image acquisition period

var QA_BAND = 'cs';         // Cloud score band
var CLEAR_THRESHOLD = 0.6;  // Cloud masking threshold

// ----------------------------------------------------
// 3. Generate Cloud-Free Median Composite
// ----------------------------------------------------

var composite = s2 // This is the image collection with useful bands
  .filterBounds(roi) // This retains only collections touched by region of interest
  .linkCollection(cs_plus, [QA_BAND]) // Links the collection to cloud masking collection
  .map(function(img){ // Ensure that all images are checked for  cloudiness
    return img.updateMask(img.select(QA_BAND).gte(CLEAR_THRESHOLD)); // Keep clear pixels only
  })
  .median() // Takes the median of all 'cloud-free' collections
  .multiply(0.0001) // Normalize the digital numbers to top of atmosphere reflectance
  .toFloat() // Not necessary here, but can be useful when adding other variables like canopy height from meta etc
  .select('B2', 'B3', 'B4', 'B5', 'B6', 'B7', 'B8', 'B8A', 'B11', 'B12') // Dropping the cs masking band and only keeping useful bands
  .clip(roi); // Cropping and masking to the bounds of roi

// ----------------------------------------------------
// 4. Visualize Composite (True Color)
// ----------------------------------------------------
  
Map.addLayer(composite,             // The prepared image to visualize 
{
  min: 0.02,                        // The minimum value in the image (obtained in the Layers tab under Range section)
  max: 0.073,                       // The maximum value in the image (obtained in the Layers tab under Range section)
  'bands': ['B4', 'B3', 'B2']       // The optical bands to show and their order for true color composite
},'s2', false);                     // Name to show on the Layers tab and the false ensures faster view as it allows for faster computation

// ----------------------------------------------------
// 5. Prepare Sample Points
// ----------------------------------------------------

var samples = tea.merge(no_tea);  // Merge tea and non-tea training data points (can be several merges depending on number of classes).

print('The samples:', samples);   // This can be valuable to inspect the labels

// ----------------------------------------------------
// 6. Sample Composite Using 'Ground Truth' Points
// ----------------------------------------------------

var training = composite.sampleRegions({  // The image to use for training your model
  collection: samples,                    // The points to extract data at/within 
  properties: ['class'],                  // The column in the data containing information about class/category
  scale: 10});                            // Ground sampling distance to use

print('The training data:', training);    // Inspecting the extracted values for both tea and non-tea locations

// ----------------------------------------------------
// 7. Split Training and Testing Data (80/20 Split)
// ----------------------------------------------------

var trainData = training.randomColumn({ // The collection to add random column to
  columnName: 'random',                 // The name of the column to add to the featureCollection
  seed: 248,                            // A seed used when generating random numbers
  distribution: 'uniform'});            // Distribution type to use, either uniform (0, 1) or normal (mean = 0, sd = 1)

print('Training data', trainData);      // Full dataset with a random column added for splitting 

var trainset = trainData.filter(ee.Filter.lt("random", 0.8)); // About 80% for training

print('Training set', trainset);        // Inspect the training set

var testset = trainData.filter(ee.Filter.gte("random", 0.8));  // About 20% for testing

print('Testing set', testset);           // Inspect the testing set

print('Number of tea', trainset.filter(ee.Filter.gt('class', 0)).size());     // Check the balance in the training data (How many tea points)
print('Number of no tea', trainset.filter(ee.Filter.lt('class', 1)).size());  // How many no tea points

// ----------------------------------------------------
// 8. Train Random Forest Classifier
// ----------------------------------------------------

var classifier = ee.Classifier.smileRandomForest(100).train({ // Pick the classifier to use, here Random Forest
  features: trainset,                                         // Specify the dataset for training
  classProperty: 'class',                                     // Specify the class property containing classes/categories information
  inputProperties: composite.bandNames()});                   // This specify the bands/columns to use in the trainset (avoids random column)

// ----------------------------------------------------
// 9. Classify Composite Image
// ----------------------------------------------------

var classified = composite.classify(classifier); // Apply the classifier on the whole image
Map.centerObject(roi, 14);  // Set where to center the map and zoom level
Map.addLayer(classified, {min:0, max:1, palette: ['orange', 'green']}, 'classified', false); // Visualize the classified image

// ----------------------------------------------------
// 10. Accuracy Assessment
// ----------------------------------------------------

var confusion_matrix = ee.ConfusionMatrix(testset.classify(classifier).errorMatrix({ // Tabulates actual and predicted values
  actual: 'class',                // The column with class/category values
  predicted: 'classification'     // The column with predicted values/classes
}));

print('Confusion matrix', confusion_matrix); // Show the output of the matrix

var overall_accuracy = confusion_matrix.accuracy();               // Overall Accuracy
print('Overall Accuracy:', overall_accuracy);

var kappa = confusion_matrix.kappa();                             // Kappa Coefficient
print('Kappa Coefficient:', kappa);

var producers_accuracy = confusion_matrix.producersAccuracy();    // Producer's Accuracy (Recall)
print("Producer's Accuracy (Recall):", producers_accuracy);

var users_accuracy = confusion_matrix.consumersAccuracy();        // User's Accuracy (Precision)
print("User's Accuracy (Precision):", users_accuracy);

var f1_score = confusion_matrix.fscore();                         // F1 Score
print("F1 Score:", f1_score);

// ----------------------------------------------------
// 11. Export Classified Image to Google Drive
// ----------------------------------------------------

Export.image.toDrive({                // Function call that exports the classified image to Google Drive
  image: classified,                  // The classified image to be exported
  description: 'cart_class',          // Name to appear on the Tasks bar
  folder: 'my_tea',                   // Folder to store the output/the classified image inside the Google Drive
  fileNamePrefix: 'gee_prediction',   // Name of the classified image that will be shown in the Google Drive
  region: roi,                        // Region bounds to be exported
  scale: 10,                          // Ground sampling distance to export the image at.
  crs: 'EPSG:3857',                   // The projection to export the image in, default is 4326/WGS84
  maxPixels: 1e13,                    // Number of pixels to chunk the export at
});

// ----------------------------------------------------
// 12. Variable Importance (Band Contribution to the RF)
// ----------------------------------------------------

var explain = classifier.explain(); // Describes the result of the classifier
print("Explain", explain);

// ----------------------------------------------------
// 13. Plot Variable Importance Chart
// ----------------------------------------------------

var variable_importance = ee.Feature(null, ee.Dictionary(explain).get("importance")); // Get only variable importance information from the Dictionary

print('Variable importance', variable_importance); // Show the variable importance values

var chartTitle = 'Random Forest: Bands Variable Importance'; // Title that will go to the chart

var chart =
  ui.Chart.feature.byProperty(variable_importance)  // Feature to plot its properties
    .setChartType('BarChart')                       // Specify the type of the chart to be bar
    .setOptions({
      title: chartTitle,                            // Specify the chart title, already defined
      legend: {position: 'none'},                   // Whether to show legend, not needed here
      hAxis: {title: 'Importance'},                 // Horizontal axis label
      vAxis: {title: 'Bands'},                      // Vertical axis label
    });
  chart.style().set({
      position: 'bottom-left',                      // Where to put the chart within the Mapping area
      width: '400px',                               // Width of the chart
      height: '400px'                               // Height of the chart
    });

Map.add(chart);                                     // Includes the chart in map area

// ----------------------------------------------------
// End of Script Summary
// ----------------------------------------------------

/*
This script builds a machine learning pipeline in Google Earth Engine (GEE)
to classify tea plantations using Sentinel-2 imagery and Random Forest classifier.

Workflow includes:
- Cloud masking and median compositing of Sentinel-2 satellite imagery
- Sampling based on field labels (tea vs. non-tea), interactively digitized using 'satelitte basemap' (Be careful)
- Training/testing split for classifier evaluation using a random column
- Classification and accuracy metrics reporting
- Exporting results for offline use
- Visualization of band importance for model interpretability

This workflow is a reproducible and modifiable template
for land use classification in agricultural landscapes.
*/