// function normalizedDifference(a, b) {
//  return ((a - b) / (a + b));
//};

var normalizedDifference = function (a, b) {
  var res = ((a - b) / (a + b));
  return res;
}


// Normalized difference between 20 and 50
var res = normalizedDifference(20, 50);
print(res);

// How about between 30 and 60?
var res = normalizedDifference(30, 60);
print(res);



