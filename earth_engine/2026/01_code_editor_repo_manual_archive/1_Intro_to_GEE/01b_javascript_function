// Normalized difference between two numbers a and b is (a - b) / (a + b)

// Calculate normalized difference between 20 and 50
var res = (20 - 50) / (20 + 50);
print(res);

// How about between 30 and 60?
var res = (30 - 60) / (30 + 60);
print(res);

