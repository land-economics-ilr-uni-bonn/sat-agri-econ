//// Create a function to aggregate Landsat data for a given year; we can then map the function over a list of years

function makeYearlyLandsatComposite (year) {

  var start = ee.Date.fromYMD(year, 1, 1)
  
  var end = start.advance(1, 'year')
  
  var filterYear = ee.Filter.date(start, end)

  var landsatColFinalYear = landsatColFinal
                            .filter(filterYear)

  var reduced = landsatColFinalYear.reduce(params.annualReducer);
  
  var old_names = reduced.bandNames();
  
  var new_names = old_names.map(function(element){return ee.String(element).cat('_').cat(ee.Number(year).int().format())})
  
  return reduced.select(old_names, new_names);
    
}


