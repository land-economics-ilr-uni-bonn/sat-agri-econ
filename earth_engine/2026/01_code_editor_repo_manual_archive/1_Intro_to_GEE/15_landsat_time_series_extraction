// Function to extract image properties and set them to feature properties
function extractImageProperties(img) {
  // Get the datetime of the image
  var datetime = img.get('system:time_start');
  // Convert the timestamp to a human-readable date string
  var date = ee.Date(datetime).format(params.datetimeFormat);
  
  // Create a dictionary with the image properties
  var imgProps = ee.Dictionary({
    'datetime': date,
    'timestamp': datetime
  });

  // Return the image properties dictionary
  return imgProps;
}


// Modify the zonalStats function to handle unexpected properties
function zonalStats(ic, fc, params) {
  // Initialize internal params dictionary.
  var _params = {
    reducer: ee.Reducer.mean(),
    scale: null,
    crs: null,
    bands: null,
    datetimeName: 'datetime',
    datetimeFormat: 'YYYY-MM-dd HH:mm:ss'
  };

  // Replace initialized params with provided params.
  if (params) {
    for (var param in params) {
      _params[param] = params[param] || _params[param];
    }
  }

  // Map the reduceRegions function over the image collection.
  var results = ic.map(function(img) {
    // Select bands
    img = ee.Image(img.select(_params.bands));

    // Define final image property dictionary to set in output features.
    var imgProps = extractImageProperties(img);

    // Subset points that intersect the given image.
    var fcSub = fc.filterBounds(img.geometry());

    // Reduce the image by regions.
    return img.reduceRegions({
      collection: fcSub,
      reducer: _params.reducer,
      scale: _params.scale,
      crs: _params.crs,
      tileScale: 1                         //// try changing to 4 if scaling errors
    })
    // Add metadata to each feature.
    .map(function(f) {
      return f.set(imgProps);
    });
  }).flatten();

  return results;
}



function extractDataFuncV3(covariates_image, sample_locations) {
  
  var extracted = covariates_image.reduceRegions({
    collection: sample_locations, 
    reducer: ee.Reducer.mean(), 
    scale: params.dataExtractionScale, 
    tileScale: 4
  })
           
  
  return extracted;
  
}
  