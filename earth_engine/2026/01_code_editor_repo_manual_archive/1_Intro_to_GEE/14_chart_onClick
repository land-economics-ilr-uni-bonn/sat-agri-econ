var points = ee.FeatureCollection("users/hadicu06/tutorial_investment_and_finance/sandbox/samplesFromMapLc");


points = points.map( function (ft) { return ft.set('Map_str', ee.Number(ft.get('Map')).format()) } );


var labels = points.distinct('Map_str')
                          .sort('n', false)
                          .reduceColumns(ee.Reducer.toList(), ['Map_str'])
                          .get('list');
                          

print("labels", labels);


var config = {};

config.selLabel = "1";


var uiSelLabel = ui.Select({
  
    items: labels.getInfo(), 
    
    value: config.selLabel,
    
    onChange: function(value){
      config.selLabel = value;
      updatePoints();
    },
    
    style: {'position': 'top-center'}
  });

Map.add(ui.Label('Select label:', {'position': 'bottom-center'})); 

Map.add(uiSelLabel);  


// Need to initialize the layer 
var points_init = points
        .filter(ee.Filter.eq('Map_str', config.selLabel));
        
Map.addLayer(points_init, {color:'yellow'}, "Selected samples (yellow)");


function updatePoints(){
  
  var selPoints = points
        .filter(ee.Filter.eq('Map_str', config.selLabel));
        
  Map.layers().set(0, ui.Map.Layer(selPoints, {color:'yellow'}, "Selected samples (yellow)"));
  
  
}

