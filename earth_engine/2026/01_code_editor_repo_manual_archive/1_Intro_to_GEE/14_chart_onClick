Map.onClick(function(coords) {

  // Add a red dot for the point clicked on.
  var point = ee.Geometry.Point(coords.lon, coords.lat);
  var dot = ui.Map.Layer(point, {color: 'FF0000'}, 'Clicked point');
  Map.layers().set(0, dot);

  // Get and filter image collection at that point, calculate NDMI index
  
  var L5 = ee.ImageCollection("LANDSAT/LT05/C02/T1_L2");
  var L7 = ee.ImageCollection("LANDSAT/LE07/C02/T1_L2");
  var L8 = ee.ImageCollection("LANDSAT/LC08/C02/T1_L2");
  var L9 = ee.ImageCollection("LANDSAT/LC09/C02/T1_L2");

    
  // Mapping of band-names to a uniform naming scheme
  var l5Bands = ['SR_B1','SR_B2','SR_B3','SR_B4','SR_B5','SR_B7']
  var l5names = ['blue','green','red','nir','swir1','swir2']
  
  var l7Bands = ['SR_B1','SR_B2','SR_B3','SR_B4','SR_B5','SR_B7']
  var l7names = ['blue','green','red','nir','swir1','swir2']
  
  var l8Bands = ['SR_B2','SR_B3','SR_B4','SR_B5','SR_B6','SR_B7']
  var l8names = ['blue','green','red','nir','swir1','swir2']

  var l9Bands = ['SR_B2','SR_B3','SR_B4','SR_B5','SR_B6','SR_B7']
  var l9names = ['blue','green','red','nir','swir1','swir2']
  
  

  var l5filtered = L5
      .filterDate(params.startDate, params.endDate)
      .filterBounds(point)
      .map(scaleL457sr)
      .map(maskL457sr)
      .select(l5Bands,l5names)
      .map(addOpticIndices)

  
  var l7filtered = L7
      .filterDate(params.startDate, params.endDate)
      .filterBounds(point)
      .map(scaleL457sr)
      .map(maskL457sr)
      .select(l7Bands,l7names)
      .map(addOpticIndices)


  var l8filtered = L8
      .filterDate(params.startDate, params.endDate)
      .filterBounds(point)
      .map(scaleL457sr)
      .map(maskL8sr)
      .select(l8Bands,l8names)
      .map(addOpticIndices)
      
      
  // var l9filtered = L9
  //     .filterDate(params.startDate, params.endDate)
  //     .filterBounds(point)
  //     .map(scaleL8sr)
  //     .map(maskL8sr)
  //     .select(l9Bands,l9names)
  //     .map(addOpticIndices)
      
  var l_merged = l5filtered.merge(l7filtered).merge(l8filtered)
  //.merge(l9filtered)
  
  print("l_merged", l_merged)
  
  
  // Make time series chart of NDMI 
  var tsChart = ui.Chart.image.series({
    imageCollection: l_merged.select(['ndvi']), 
    region: point, 
    reducer: ee.Reducer.mean(),
    scale: 30
  });
  
  // Customize the chart
  tsChart = tsChart
  .setOptions({
    title: 'Landsat time series',
    pointSize: 3,
    lineWidth: 0});
   
   
  // Insert the chart widget into the panel          
  panel.widgets().set(0, tsChart);
  
});


