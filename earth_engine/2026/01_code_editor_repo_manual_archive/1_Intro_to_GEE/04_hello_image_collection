// Load Sentinel-2 satellite images, surface reflectance product
// var S2 = ee.ImageCollection("COPERNICUS/S2_SR");
var S2 = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED");

// Filter for images for one day
// var selectedIm = imCollection.filterDate(startDate, stopDate);
var filtered = S2.filterDate('2023-08-01', '2023-08-02');

print('filtered', filtered);
print('filtered.size()', filtered.size());
print('filtered.first()', filtered.first());


// Visualize the image on the map. First, as RGB.
var rgb_vis = {
  min: 0,
  max: 3000,
  bands: ['B4', 'B3', 'B2'] // Red, Green, Blue
};

Map.addLayer(filtered, rgb_vis, 'RGB', true);

// Add a false-color visualization. Band B11 is Shortware Infrared 1. Band B8 is Near Infrared.
Map.addLayer(filtered, 
      {min: [0, 0, 0], 
       max: [4000, 6000, 3000], 
       bands: ['B11', 'B8', 'B4']}, 
      'False Color',
      false);


