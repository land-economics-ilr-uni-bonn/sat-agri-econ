var clientNumber = 10;

var serverNumber = ee.Number(10);

// Don't mix EE objects and JavaScript objects:
var nonsense = serverNumber + 2;

// You can print this, but it's not what you were hoping for.
print('nonsense', nonsense);


// Instead, use server-side function/method!
var ok = serverNumber.add(2);
print('ok', ok);
