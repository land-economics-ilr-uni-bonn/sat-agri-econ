////---------------------------------------------------------
//// Sentinel-2, multitemporal composites
////---------------------------------------------------------


var s2 = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED');
var csPlus = ee.ImageCollection('GOOGLE/CLOUD_SCORE_PLUS/V1/S2_HARMONIZED');


var s2_seasons = ee.List.sequence(1, 12, 3).map(function(month) {
  month = ee.Number(month)
  var seasons = s2
    .filterBounds(geometry)
    .filterDate('2019-01-01', '2021-12-31')
    .linkCollection(csPlus, ['cs'])
    .map(function(img) {
      return img.updateMask(img.select('cs').gte(0.60));
    })
    .filter(ee.Filter.calendarRange(month, month.add(2), 'month'))
    .select('B.*')

  // Create a composite from means at different polarizations and look angles.
  var seasons_composites = seasons.mean()
  return seasons_composites
})

var s2_seasons_composites = ee.ImageCollection.fromImages(s2_seasons).toBands()

print("s2_seasons_composites", s2_seasons_composites)

var old_names = s2_seasons_composites.bandNames();

print("old_names", old_names);

var new_names = old_names.map(function(name) {
  return ee.String('season_').cat(name);
});

print("new_names", new_names);

s2_seasons_composites = s2_seasons_composites.select(old_names, new_names);

print("s2_seasons_composites", s2_seasons_composites)


