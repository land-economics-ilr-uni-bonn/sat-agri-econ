var geometry = /* color: #d63000 */ee.Geometry.Point([104.74551156654312, -2.9714700800585607]);

Map.centerObject(geometry, 10);
  
// Load Landsat-8 surface reflectance
var L8 = ee.ImageCollection("LANDSAT/LC08/C02/T1_L2");

print("L8.first()", L8.first())

// Filter the Landsat image collection
var filtered = L8.filterDate('2019-01-01', '2021-12-31')
                 .filter('CLOUD_COVER_LAND < 50')
                 .filterBounds(hadi);

// Apply scaling and offset
var applyScaleAndOffset = function(image) {
  var opticalBands = image.select('SR_B.').multiply(0.0000275).add(-0.2);
  var thermalBands = image.select('ST_B.*').multiply(0.00341802).add(149.0);
  return image.addBands(opticalBands, null, true).addBands(thermalBands, null, true);
};

filtered = filtered.map(applyScaleAndOffset);



// Mask non-clear pixels
// see also https://d9-wret.s3.us-west-2.amazonaws.com/assets/palladium/production/s3fs-public/media/files/LSDS-1619_Landsat8-9-Collection2-Level2-Science-Product-Guide-v5.pdf

// Create a function to mask clouds and shadows in an image
// Bit 1: Dilated Cloud
// Bit 2: Cirrus (high confidence)
// Bit 3: Cloud
// Bit 4: Cloud Shadow
// Bit 5: Snow
var maskClouds = function (image) {
  var qa = image.select('QA_PIXEL');
  var cloudShadowBitMask = 1 << 3;
  var cloudBitMask = 1 << 4;
  var cloudMask = qa.bitwiseAnd(cloudShadowBitMask).eq(0).and(qa.bitwiseAnd(cloudBitMask).eq(0));
  return image.updateMask(cloudMask);
};

// Map the mask function to each image in the image collection
var cloudMasked = filtered.map(maskClouds);


// Create a median composite
var composite = cloudMasked.median();

print('composite', composite);

Map.addLayer(composite, {min:0, max:0.2, bands:['SR_B4', 'SR_B3', 'SR_B2']}, 'Median composite');
  


// Keep only reflective bands
var composite_refl = composite.select('SR_B.');

print("composite_refl", composite_refl);



// Scale value by 10000, cast data type to signed 16-bit integer, to minimize data storage
var composite_refl_int = composite_refl.multiply(10000).round().toInt16();

composite_refl_int = composite_refl_int.set('scaling_factor', 10000);

print("composite_refl_int", composite_refl_int);



